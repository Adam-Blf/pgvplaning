// Firestore Security Rules for Absencia
// These rules define who can read/write which documents.
// NEVER rely solely on client-side checks — these are the real security boundary.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/super_admins/$(request.auth.uid));
    }

    function isTeamMember(teamId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid));
    }

    function isTeamLeader(teamId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid)).data.role == 'leader';
    }

    function isTeamLeaderOrMod(teamId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid)).data.role in ['leader', 'moderator'];
    }

    // ─── Super Admins ────────────────────────────────────────────────────
    match /super_admins/{userId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ─── Profiles ──────────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isAuthenticated();
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'teamId']);
      // Super admin can update any profile
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ─── Teams ─────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isTeamLeaderOrMod(teamId) || isSuperAdmin();
      allow delete: if isTeamLeader(teamId) || isSuperAdmin();
    }

    // ─── Team Memberships ───────────────────────────────────────────────────
    match /team_members/{membershipId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isTeamLeaderOrMod(membershipId.split('_')[0]) || isSuperAdmin();
      allow delete: if isTeamLeader(membershipId.split('_')[0]) || isSuperAdmin();
    }

    // ─── Pre-created members ────────────────────────────────────────────────
    match /pre_created_members/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ─── Calendars ──────────────────────────────────────────────────────────
    match /calendars/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isSuperAdmin();
    }

    // ─── Leave Balance — server-side write only ─────────────────────────────
    match /leave_balances/{userId} {
      allow read: if isOwner(userId) || isAuthenticated();
      allow write: if false;
    }

    // ─── Invitations ────────────────────────────────────────────────────────
    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // ─── Team Invitations ───────────────────────────────────────────────────
    match /team_invitations/{invitationId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ─── Deny everything else by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
