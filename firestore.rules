// Firestore Security Rules for Absencia
// These rules define who can read/write which documents.
// NEVER rely solely on client-side checks — these are the real security boundary.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid));
    }

    function isTeamLeader(teamId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid)).data.role == 'leader';
    }

    // ─── Profiles ──────────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isAuthenticated();
      // Users can update their own profile but NOT role or teamId (admin-controlled)
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'teamId']);
      allow delete: if false;
    }

    // ─── Teams ─────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isEmailVerified();
      allow update: if isTeamLeader(teamId);
      allow delete: if false;
    }

    // ─── Team Memberships ───────────────────────────────────────────────────
    match /team_members/{membershipId} {
      allow read: if isAuthenticated();
      allow update: if isTeamLeader(membershipId.split('_')[0]);
      allow create: if isEmailVerified();
      allow delete: if isTeamLeader(membershipId.split('_')[0]);
    }

    // ─── Calendars ──────────────────────────────────────────────────────────
    match /calendars/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isEmailVerified();
    }

    // ─── Leave Balance — server-side write only ─────────────────────────────
    match /leave_balances/{userId} {
      allow read: if isOwner(userId) || isAuthenticated();
      allow write: if false;
    }

    // ─── Invitations ────────────────────────────────────────────────────────
    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // ─── Deny everything else by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
